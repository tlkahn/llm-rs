#!/bin/sh
if [ "$1" = "--schema" ]; then
    echo '{"name":"upper","description":"Uppercase text","input_schema":{"type":"object","properties":{"text":{"type":"string"}},"required":["text"]}}'
    exit 0
fi
read input
echo "$input" | python3 -c "import sys,json; print(json.load(sys.stdin)['text'].upper())"
